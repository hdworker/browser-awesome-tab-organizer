{
  "manifest_version": 3,
  "name": "yandex Tab Sorter v2",
  "version": "1.0",
  "description": "Сортировщик вкладок для Яндекс Браузера",
  "permissions": ["tabs", "storage", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": ["http://*/*", "https://*/*"]
}